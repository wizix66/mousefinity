/target
daemon.err
daemon.out
probe.txt
.claude/

# Locally built binaries for testing before a release. The published ones
# come from release.yml, which also emits the SHA256SUMS `upgrade` verifies;
# these are unsigned throwaways and must never be committed or shipped.
/dist/

# CycloneDX SBOMs are generated from Cargo.lock on demand and attached to
# releases by release.yml; a committed copy would just go stale.
*.cdx.json
